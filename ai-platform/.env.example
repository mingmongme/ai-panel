# AI for You — environment variable reference
#
# This file is the source of truth for every env var the api-server (and the
# install.sh app.env it writes) can read. `scripts/check-env-example.sh` diffs
# this file against install.sh and the api-server source and fails if a var
# used in code is missing here — keep it in sync whenever you add a new
# process.env[...] read or a new key to the install.sh app.env heredoc.

# --- Written by install.sh into /opt/ai-platform/app.env ---

# Standard Node runtime mode. install.sh always sets "production".
NODE_ENV=production

# Port the api-server listens on (Caddy reverse-proxies to this).
PORT=8080

# Public domain the app is served on (used for Caddy, OpenRouter HTTP-Referer header).
DOMAIN=ai.abcomputers.info

# Session cookie signing secret. install.sh generates this with `openssl rand -hex 32`.
SESSION_SECRET=

# Base URL of the local Ollama server.
OLLAMA_BASE_URL=http://127.0.0.1:11434

# Absolute path to the built frontend (dist/public) to serve as static files.
FRONTEND_DIST=

# Absolute path to the writable data directory (conversations, users, backups, etc).
DATA_DIR=

# Absolute path to the workspace/projects root used by the file explorer and agent tools.
FILES_ROOT=

# pino log level (trace|debug|info|warn|error|fatal). Defaults to "info" if unset.
LOG_LEVEL=info

# --- Optional, not written by install.sh — set manually on the VPS if needed ---

# API key for OpenRouter-backed cloud models (multi-provider chat). Falls back to
# OPENAI_API_KEY if unset. Leave blank to use only local Ollama models.
OPENROUTER_API_KEY=

# Fallback key used if OPENROUTER_API_KEY is not set.
OPENAI_API_KEY=

# Base URL of a self-hosted SearXNG instance for agent web search.
# When set, search queries use SearXNG's JSON API instead of scraping DuckDuckGo.
# Example (local install on VPS): http://localhost:8888
SEARXNG_URL=

# Bearer key required on the OpenAI-compatible /v1 API. Blank = no auth required (permissive).
V1_API_KEY=

# Disk-usage percentage threshold that triggers a maintenance-scheduler alert. Defaults to 80.
DISK_ALERT_PCT=80

# RAM (in GB) the maintenance scheduler assumes Ollama needs headroom for before pulling/loading
# a model. Defaults to 12.
OLLAMA_RAM_GUARD_GB=12

# Absolute path to the system Chromium executable used by the browser-agent tool.
# install.sh sets this automatically when it finds Chromium; leave blank to disable the
# browser-agent feature until Chromium is installed manually.
CHROMIUM_PATH=

# --- WhatsApp (Twilio) --- optional, enables send_whatsapp agent tool ---

# Twilio Account SID (from console.twilio.com)
TWILIO_ACCOUNT_SID=

# Twilio Auth Token (from console.twilio.com)
TWILIO_AUTH_TOKEN=

# WhatsApp-enabled Twilio number (sandbox default shown; replace with your approved number)
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
